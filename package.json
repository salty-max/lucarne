{
  "name": "lucarne",
  "version": "0.1.0",
  "private": true,
  "description": "Football schedule with French broadcasters (diffuseurs)",
  "license": "MIT",
  "workspaces": ["apps/*", "packages/*"],
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "turbo run dev",
    "dev:match": "caffeinate -is turbo run dev",
    "dev:pwa": "bun run --filter @lucarne/web build && bun run --filter @lucarne/api start",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "deploy": "turbo run deploy",
    "dryrun": "turbo run dryrun",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "turbo run test",
    "prepare": "husky",
    "db:generate": "bun run --filter @lucarne/api db:generate",
    "db:migrate": "bun run --filter @lucarne/api db:migrate",
    "db:seed": "bun run --filter @lucarne/api db:seed"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "turbo": "^2",
    "typescript-eslint": "^8.64.0"
  }
}
