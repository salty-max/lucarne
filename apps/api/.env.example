# --- Database ---
# Postgres, everywhere. Local dev points at the docker-compose Postgres; prod
# (Northflank) injects its managed Postgres addon URL — link the addon to the
# service so DATABASE_URL is set for you. Append ?sslmode=require if the managed
# instance enforces TLS. Optional locally; defaults to the compose credentials.
# DATABASE_URL="postgres://lucarne:lucarne@localhost:5432/lucarne"

# --- API-Football (api-sports.io) ---
# Free plan = 100 requests/day. Get a key at https://dashboard.api-football.com
API_FOOTBALL_KEY="your_api_football_key"

# --- Cron / poller auth ---
# Protects the /api/cron/* endpoints. Send `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET="generate_a_long_random_string"

# --- Season currently being ingested (API-Football uses the starting year) ---
CURRENT_SEASON="2025"

# --- Web Push (VAPID) ---
# Generate a keypair once (see scripts/gen-vapid or `npx web-push generate-vapid-keys`).
# The private key is a SECRET — keep it out of git; in prod add it as a Northflank
# secret env var on the service. The client fetches the public key at runtime from
# /api/push/key, so nothing VAPID needs to be baked into the web build.
VAPID_PUBLIC_KEY="your_vapid_public_key_base64url"
VAPID_PRIVATE_KEY="your_vapid_private_key_base64url"
VAPID_SUBJECT="mailto:you@example.com"

# --- Logging (prod) ---
# Structured JSON logs for the platform log viewer; omit for pretty local logs.
# LOG_FORMAT="json"
