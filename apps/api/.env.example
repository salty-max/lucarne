# --- Database ---
# Prod is Cloudflare D1 (a Worker binding — no connection string here).
# Local dev / Bun uses a bun:sqlite file. Optional; defaults to ./local.db
# SQLITE_PATH="local.db"

# --- API-Football (api-sports.io) ---
# Free plan = 100 requests/day. Get a key at https://dashboard.api-football.com
API_FOOTBALL_KEY="your_api_football_key"

# --- Cron / poller auth ---
# Protects the /api/cron/* endpoints. Send `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET="generate_a_long_random_string"

# --- Season currently being ingested (API-Football uses the starting year) ---
CURRENT_SEASON="2025"

# --- Web Push (VAPID) ---
# Generate a keypair once (see scripts/gen-vapid or `npx web-push generate-vapid-keys`).
# The private key is a SECRET — keep it out of git; set it in prod via `wrangler secret put`.
VAPID_PUBLIC_KEY="your_vapid_public_key_base64url"
VAPID_PRIVATE_KEY="your_vapid_private_key_base64url"
VAPID_SUBJECT="mailto:you@example.com"
